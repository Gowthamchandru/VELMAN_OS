# GC OS assistant server — copy this file to `.env` and fill in your token.
# `.env` is gitignored and never leaves your machine.

# Your Claude Pro/Max subscription token. Get it once with:
#   npm i -g @anthropic-ai/claude-code
#   claude setup-token         (opens a browser login to your Pro account)
# then paste the printed token here. Calls will draw on your Pro plan.
CLAUDE_CODE_OAUTH_TOKEN=your-claude-code-oauth-token-here

# Optional overrides:
# GCOS_MODEL=sonnet          # 'sonnet' (Pro default) | 'opus' (needs Max) | full model id
# GCOS_SERVER_PORT=8787
